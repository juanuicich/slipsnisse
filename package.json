{
  "name": "slipsnisse",
  "version": "1.0.0",
  "description": "MCP server that exposes AI-powered composite tools",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "slipsnisse": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "keywords": [
    "mcp",
    "ai",
    "tools",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@tanstack/ai": "^0.2.2",
    "@tanstack/ai-anthropic": "^0.2.0",
    "@tanstack/ai-gemini": "^0.3.2",
    "@tanstack/ai-openai": "^0.2.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/node": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
